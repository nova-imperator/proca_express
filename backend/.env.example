# --- App ---
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:3000     # frontend origin (used in password-reset links)

# --- CORS allow-list (comma-separated). Must include the frontend origin. ---
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-me-with-openssl-rand-hex-32
# Set to "true" ONLY when the site is served over HTTPS (Certbot/nginx 443).
# On plain HTTP, browsers silently drop Secure cookies → users stay logged out.
COOKIE_SECURE=false

# --- PostgreSQL (RDS) ---
PGHOST=your-db.xxxxxxxx.ap-south-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=proca_express
PGUSER=postgres
PGPASSWORD=
PGSSL=true

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Proca Express <no-reply@procaexpress.in>"
MAIL_ADMIN_NOTIFY=admin@procaexpress.in

# --- Bootstrap admin (only used on first db:init) ---
BOOTSTRAP_ADMIN_EMAIL=admin@procaexpress.in
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@123

# --- MindLabs integration ---
# API key from app.mindlabs.cloud → Settings → Integrations → API Keys
MINDLABS_API_KEY=
MINDLABS_API_BASE=https://api.mindlabs.cloud
# Your MindLabs organization id (visible in their dashboard). Required for iframe embeds.
MINDLABS_ORG_ID=
# Optional shared-secret enforced as ?token=... on the inbound webhook URL.
# Leave empty during initial test; set once MindLabs allows arbitrary URLs and
# you want a bit of extra protection against drive-by POSTs.
MINDLABS_WEBHOOK_TOKEN=
