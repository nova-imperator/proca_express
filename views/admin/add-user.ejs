<%- include('../partials/head') %>
<%- include('../partials/admin-nav') %>

<main class="container narrow">
  <h1>Add user</h1>
  <% if (error) { %><div class="notice error"><%= error %></div><% } %>
  <form method="post" action="/admin/add-user" class="card">
    <label>Email <span class="req">*</span>
      <input type="email" name="email" value="<%= form.email || '' %>" required />
    </label>
    <label>Mobile <span class="req">*</span>
      <input type="tel" name="mobile" value="<%= form.mobile || '' %>" required />
    </label>
    <label>Password <span class="req">*</span>
      <input type="password" name="password" required minlength="8" />
    </label>
    <label>Confirm password <span class="req">*</span>
      <input type="password" name="confirm" required minlength="8" />
    </label>
    <label>Full name
      <input type="text" name="full_name" value="<%= form.full_name || '' %>" />
    </label>
    <label>Designation
      <input type="text" name="designation" value="<%= form.designation || '' %>" />
    </label>
    <label>Company name
      <input type="text" name="company_name" value="<%= form.company_name || '' %>" />
    </label>
    <label>Company GST
      <input type="text" name="company_gst" value="<%= form.company_gst || '' %>" />
    </label>
    <div class="row">
      <button class="btn primary" type="submit">Create user</button>
      <a class="btn" href="/admin/users">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
