<%- include('../partials/head') %>
<%- include('../partials/admin-nav') %>

<main class="container narrow">
  <h1>Edit user</h1>
  <% if (error) { %><div class="notice error"><%= error %></div><% } %>
  <form method="post" action="/admin/edit-user/<%= user.id %>" class="card">
    <label>Email
      <input type="email" name="email" value="<%= user.email %>" required />
    </label>
    <label>Mobile
      <input type="tel" name="mobile" value="<%= user.mobile %>" required />
    </label>
    <label>Full name
      <input type="text" name="full_name" value="<%= user.full_name || '' %>" />
    </label>
    <label>Designation
      <input type="text" name="designation" value="<%= user.designation || '' %>" />
    </label>
    <label>Company name
      <input type="text" name="company_name" value="<%= user.company_name || '' %>" />
    </label>
    <label>Company GST
      <input type="text" name="company_gst" value="<%= user.company_gst || '' %>" />
    </label>
    <label class="checkbox">
      <input type="checkbox" name="is_active" <%= user.is_active ? 'checked' : '' %> />
      Active
    </label>
    <div class="row">
      <button class="btn primary" type="submit">Save</button>
      <a class="btn" href="/admin/users">Cancel</a>
    </div>
  </form>
</main>

<%- include('../partials/foot') %>
