<%- include('../partials/head') %>
<%- include('../partials/admin-nav') %>

<main class="container">
  <div class="row-between">
    <h1>Users</h1>
    <a class="btn primary" href="/admin/add-user">Add user</a>
  </div>

  <div class="card">
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Mobile</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (!users.length) { %>
          <tr><td colspan="5" class="muted">No users yet.</td></tr>
        <% } %>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.full_name || '—' %></td>
            <td><%= u.email %></td>
            <td><%= u.mobile %></td>
            <td><%= u.is_active ? 'Active' : 'Disabled' %></td>
            <td class="actions">
              <a href="/admin/edit-user/<%= u.id %>">Edit</a>
              <a href="/admin/edit-user/<%= u.id %>">Manage</a>
              <form action="/admin/users/<%= u.id %>/delete" method="post" class="inline-form" onsubmit="return confirm('Delete this user?')">
                <button class="link-button danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<%- include('../partials/foot') %>
