<%- include('partials/head') %>
<%- include('partials/user-nav') %>

<main class="container narrow">
  <h1>Register request</h1>
  <p class="muted">Tell us about your business — our team will get back to you.</p>

  <% if (error) { %><div class="notice error"><%= error %></div><% } %>
  <% if (success) { %><div class="notice success"><%= success %></div><% } %>

  <form method="post" action="/register-request" class="card">
    <label>Email <span class="req">*</span>
      <input type="email" name="email" value="<%= form.email || '' %>" required />
    </label>
    <label>Mobile number <span class="req">*</span>
      <input type="tel" name="mobile" value="<%= form.mobile || '' %>" required />
    </label>
    <label>Full name
      <input type="text" name="full_name" value="<%= form.full_name || '' %>" />
    </label>
    <label>Designation
      <input type="text" name="designation" value="<%= form.designation || '' %>" />
    </label>
    <label>Company name
      <input type="text" name="company_name" value="<%= form.company_name || '' %>" />
    </label>
    <label>Company GST
      <input type="text" name="company_gst" value="<%= form.company_gst || '' %>" />
    </label>

    <% if (recaptchaSiteKey) { %>
      <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
      <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <% } %>

    <button type="submit" class="btn primary">Submit request</button>
  </form>

  <p><a href="/">Back to sign in</a></p>
</main>

<%- include('partials/foot') %>
